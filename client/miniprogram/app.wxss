/* ===== 全局样式 ===== */
@import 'style/weui.wxss';

page {
  background-color: #FFF9F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #2D2D2D;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ===== 通用容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5F0 100%);
  position: relative;
  overflow: hidden;
}

.page-light {
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 100%);
}

.page-gradient-green {
  background: linear-gradient(180deg, #E8F8F0 0%, #F0FFF5 100%);
}

/* ===== 背景装饰 ===== */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
}

.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #FFE4D6 0%, #FFDDD0 100%);
  top: -200rpx;
  right: -150rpx;
  opacity: 0.6;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #E8F4FF 0%, #D6EDFF 100%);
  top: 600rpx;
  left: -100rpx;
  opacity: 0.5;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE4D6 100%);
  bottom: 200rpx;
  right: -50rpx;
  opacity: 0.5;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: transparent;
}

.header-simple {
  padding: 60rpx 40rpx 20rpx;
}

.back-btn {
  font-size: 64rpx;
  color: #2D2D2D;
  padding: 0 16rpx;
  font-weight: 300;
  line-height: 1;
}

.back-btn:active {
  opacity: 0.6;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  text-align: center;
  flex: 1;
  padding-right: 80rpx;
}

/* ===== 步骤指示器 ===== */
.step-indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 0 40rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #E8E8E8;
  transition: all 0.4s ease;
}

.step-dot.active {
  width: 48rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF6B5B 100%);
}

.step-dot.completed {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

/* ===== 动画偏好检测 ===== */
@media (prefers-reduced-motion: reduce) {
  .anim-fade-in,
  .anim-slide-up {
    animation: none;
    opacity: 1;
  }
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.anim-fade-in {
  animation: fadeIn 0.5s ease-out forwards;
}

.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
}

/* ===== 卡片 ===== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-primary {
  background: linear-gradient(135deg, #FFF5F0 0%, #FFF0EA 100%);
  border: 1px solid rgba(255, 140, 105, 0.2);
}

/* ===== 按钮 ===== */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF6B5B 100%);
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 91, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 91, 0.3);
}

.btn-primary:disabled {
  background: #D0D0D0;
  box-shadow: none;
}

.btn-secondary {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #FF6B5B;
  border: 2rpx solid #FF6B5B;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: #FFF5F0;
}

.btn-green {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.btn-green:active {
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* ===== 输入框 ===== */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 16rpx;
  display: block;
}

.input {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid #E8E8E8;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #2D2D2D;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.input:focus {
  border-color: #FF8C69;
  box-shadow: 0 0 0 4rpx rgba(255, 140, 105, 0.1);
}

.input::placeholder {
  color: #B0B0B0;
}

.input-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.input-row .input {
  flex: 1;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
  transition: all 0.3s ease;
}

.nav-item.active {
  color: #FF6B5B;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 徽章 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-orange {
  background: linear-gradient(135deg, #FFE4D6 0%, #FFD6C4 100%);
  color: #FF6B5B;
}

.badge-green {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.badge-blue {
  background: linear-gradient(135deg, #E8F4FF 0%, #D6EDFF 100%);
  color: #4A90FF;
}

/* ===== 头像 ===== */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.avatar-orange {
  background: linear-gradient(135deg, #FF8C69 0%, #FF6B5B 100%);
}

.avatar-green {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.avatar-blue {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

/* ===== 分隔线 ===== */
.divider {
  height: 16rpx;
  background: #F8F8F8;
  margin: 0 -40rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #8C8C8C;
}

/* ===== Toast 提示 ===== */
.toast {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(45, 45, 45, 0.9);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
  z-index: 9999;
  backdrop-filter: blur(10rpx);
}