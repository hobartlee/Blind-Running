/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  padding-right: 60rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 32rpx 140rpx;
}

/* ===== 跑团信息卡片 ===== */
.club-card {
  background: linear-gradient(135deg, #EFF6FF 0%, #E0E7FF 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 48rpx 30rpx;
  text-align: center;
  margin: 0 -32rpx 32rpx;
  position: relative;
}

.club-avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 700;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.club-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.club-location {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.club-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #07C160;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 1px;
  height: 60rpx;
  background: #D1D5DB;
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 20rpx;
}

/* ===== 活动列表 ===== */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  flex: 1;
  margin-right: 16rpx;
}

.activity-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-upcoming {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.badge-pending {
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  color: #FF9A4D;
}

.activity-meta {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
}

.activity-footer {
  display: flex;
  justify-content: flex-end;
}

.activity-signups {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #07C160;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
