<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">{{clubName}}</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 跑团信息卡片 -->
    <view class="club-card anim-slide-up">
      <view class="club-avatar">{{clubName.charAt(0)}}</view>
      <view class="club-name">{{clubName}}</view>
      <view class="club-location">{{clubLocation}}</view>
      <view class="club-stats">
        <view class="stat-item">
          <view class="stat-value">{{memberCount}}</view>
          <view class="stat-label">名成员</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">{{activityCount}}</view>
          <view class="stat-label">期活动</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">{{helpedCount}}</view>
          <view class="stat-label">人次</view>
        </view>
      </view>
    </view>

    <!-- 跑团活动 -->
    <view class="section anim-slide-up" style="animation-delay: 0.1s">
      <view class="section-title">跑团活动</view>
      <view class="activity-list">
        <view
          class="activity-card anim-slide-up"
          wx:for="{{activities}}"
          wx:key="id"
          wx:for-index="idx"
          style="animation-delay: {{0.15 + idx * 0.05}}s"
          bindtap="goToSignups"
          data-id="{{item.id}}"
        >
          <view class="activity-header">
            <view class="activity-title">{{item.title}}</view>
            <view class="activity-badge badge-{{item.status}}">{{item.statusText}}</view>
          </view>
          <view class="activity-meta">{{item.dateText}} · {{item.location}}</view>
          <view class="activity-footer">
            <view class="activity-signups">{{item.signups}} 人报名</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToHome">
      <view class="nav-icon-text">首</view>
      <view class="nav-label">首页</view>
    </view>
    <view class="nav-item" bindtap="goToMy">
      <view class="nav-icon-text">我</view>
      <view class="nav-label">我的</view>
    </view>
  </view>
</view>
