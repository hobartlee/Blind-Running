<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部 -->
  <view class="hero">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="hero-title">手机号登录</view>
    <view class="hero-subtitle">登录后即可使用完整功能</view>
  </view>

  <!-- 卡片 -->
  <view class="content">
    <!-- 步骤1: 手机号 -->
    <view class="card" wx:if="{{step === 1}}">
      <view class="card-icon">📱</view>
      <view class="card-label">手机号</view>
      <view class="phone-row">
        <text class="phone-prefix">+86</text>
        <input
          class="phone-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="placeholder"
          bindinput="onPhoneInput"
          value="{{phone}}"
        />
      </view>
      <button
        class="btn {{phone.length === 11 ? 'btn-active' : ''}}"
        bindtap="sendCode"
        disabled="{{phone.length !== 11}}"
      >获取验证码</button>
    </view>

    <!-- 步骤2: 验证码 -->
    <view class="card" wx:if="{{step === 2}}">
      <view class="card-icon">🔐</view>
      <view class="card-label">验证码</view>
      <view class="card-desc">已发送至 {{maskedPhone}}</view>
      <view class="code-row">
        <input
          class="code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="placeholder"
          bindinput="onCodeInput"
          value="{{code}}"
        />
      </view>
      <button
        class="btn {{code.length === 6 ? 'btn-active' : ''}}"
        bindtap="doLogin"
        disabled="{{code.length !== 6}}"
      >登录</button>
      <view class="resend-row">
        <text class="{{counting ? 'resend-disabled' : 'resend'}}" bindtap="resendCode">
          {{counting ? count + '秒后重发' : '重新发送验证码'}}
        </text>
      </view>
    </view>
  </view>
</view>
