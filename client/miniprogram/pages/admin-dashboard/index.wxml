<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">账号管理</view>
    <view class="logout-btn" bindtap="logout">退出</view>
  </view>

  <!-- 标签页 -->
  <view class="tabs-wrap">
    <view class="tabs">
      <view
        class="tab {{activeTab === 'blind' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="blind"
      >
        视障跑者
        <view class="tab-badge" wx:if="{{blindCount > 0}}">{{blindCount}}</view>
      </view>
      <view
        class="tab {{activeTab === 'volunteer' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="volunteer"
      >
        志愿者
        <view class="tab-badge" wx:if="{{volunteerCount > 0}}">{{volunteerCount}}</view>
      </view>
      <view
        class="tab {{activeTab === 'club' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="club"
      >
        跑团
        <view class="tab-badge" wx:if="{{clubCount > 0}}">{{clubCount}}</view>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 视障跑者列表 -->
    <view class="tab-content {{activeTab === 'blind' ? 'active' : ''}}">
      <view class="account-card anim-slide-up" wx:for="{{blindList}}" wx:key="id">
        <view class="account-info">
          <view class="account-avatar blind">{{item.name ? item.name[0] : '盲'}}</view>
          <view class="account-detail">
            <view class="account-name">{{item.name || '未填写姓名'}}</view>
            <view class="account-meta">{{item.phone}} · {{item.genderText || '未填写'}} · {{item.age || '?'}}岁</view>
            <view class="account-meta">跑步经验：{{item.experienceText || '未填写'}}</view>
          </view>
          <view class="account-status status-{{item.certStatus || 'unverified'}}">
            {{item.certStatusText || '未认证'}}
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{blindList.length === 0}}">
        <view class="empty-icon-text">~</view>
        <view class="empty-title">暂无视障跑者</view>
      </view>
    </view>

    <!-- 志愿者列表 -->
    <view class="tab-content {{activeTab === 'volunteer' ? 'active' : ''}}">
      <view class="account-card anim-slide-up" wx:for="{{volunteerList}}" wx:key="id">
        <view class="account-info">
          <view class="account-avatar volunteer">{{item.name ? item.name[0] : '志'}}</view>
          <view class="account-detail">
            <view class="account-name">{{item.name || '未填写姓名'}}</view>
            <view class="account-meta">{{item.phone}}</view>
            <view class="account-meta">{{item.genderText || '未填写'}} · {{item.experienceText || '未填写'}}</view>
          </view>
          <view class="account-status status-{{item.clubStatus || 'none'}}">
            {{item.clubStatusText || '未加入跑团'}}
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{volunteerList.length === 0}}">
        <view class="empty-icon-text">~</view>
        <view class="empty-title">暂无志愿者</view>
      </view>
    </view>

    <!-- 跑团列表 -->
    <view class="tab-content {{activeTab === 'club' ? 'active' : ''}}">
      <view class="account-card anim-slide-up" wx:for="{{clubList}}" wx:key="id">
        <view class="account-info">
          <view class="account-avatar-text club">{{item.name ? item.name[0] : '跑'}}</view>
          <view class="account-detail">
            <view class="account-name">{{item.name}}</view>
            <view class="account-meta">{{item.location}}</view>
            <view class="account-meta">负责人：{{item.phone}}</view>
          </view>
          <view class="account-status status-verified">
            {{item.memberCount || 0}} 名志愿者
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{clubList.length === 0}}">
        <view class="empty-icon-text">~</view>
        <view class="empty-title">暂无跑团</view>
      </view>
    </view>
  </view>
</view>
