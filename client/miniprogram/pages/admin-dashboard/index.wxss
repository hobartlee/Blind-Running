/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: #F7F7F7;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.logout-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 8rpx 16rpx;
}

/* ===== 标签页 ===== */
.tabs-wrap {
  padding: 24rpx 32rpx 0;
  background: #fff;
}

.tabs {
  display: flex;
  background: #F7F7F7;
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  padding: 18rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  text-align: center;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab.active {
  background: #fff;
  color: #1a1a1a;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tab-badge {
  background: #FF6B5B;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  font-weight: 700;
}

.tab.active .tab-badge {
  background: #1a1a1a;
}

/* ===== 内容区域 ===== */
.content {
  padding: 24rpx 32rpx;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* ===== 账号卡片 ===== */
.account-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.account-info {
  display: flex;
  align-items: flex-start;
}

.account-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.account-avatar.blind {
  background: linear-gradient(135deg, #FF9A7A 0%, #FF8C69 100%);
}

.account-avatar.volunteer {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.account-avatar.club {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.account-detail {
  flex: 1;
}

.account-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.account-meta {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.account-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.status-verified {
  background: #E8F8F0;
  color: #07C160;
}

.status-pending {
  background: #FFF5E8;
  color: #FF9A4D;
}

.status-unverified {
  background: #F5F5F5;
  color: #8C8C8C;
}

.status-joined {
  background: #E8F8F0;
  color: #07C160;
}

.status-none {
  background: #F5F5F5;
  color: #8C8C8C;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #8C8C8C;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.4s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
