/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #FF9A7A 0%, #FF8C69 100%);
}

.header-left {
  display: flex;
  align-items: center;
}

.logo-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.header-right {
  display: flex;
  align-items: center;
}

.switch-btn {
  font-size: 24rpx;
  color: #fff;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 24rpx 40rpx 160rpx;
}

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB399 0%, #FF9A7A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.user-avatar-text {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB399 0%, #FF9A7A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 26rpx;
  color: #8C8C8C;
}

.user-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE4D6 100%);
  color: #FF6B5B;
  border-radius: 100rpx;
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.section-more {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 报名卡片 ===== */
.signup-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.signup-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.signup-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.signup-status.confirmed {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.signup-status.pending {
  background: linear-gradient(135deg, #FFB366 0%, #FF9A4D 100%);
}

.signup-info {
  flex: 1;
}

.signup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.signup-meta {
  font-size: 24rpx;
  color: #8C8C8C;
}

.signup-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-confirmed {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.badge-pending {
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  color: #FF9A4D;
}

/* ===== 分隔线 ===== */
.divider-line {
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #E8E8E8 50%, transparent 100%);
  margin: 8rpx 0 32rpx;
}

/* ===== 活动列表 ===== */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  flex: 1;
  margin-right: 16rpx;
}

.activity-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

.activity-badge.club {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.meta-icon {
  font-size: 24rpx;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1px solid #F5F5F5;
}

.activity-author {
  font-size: 26rpx;
  color: #8C8C8C;
}

.activity-signups {
  font-size: 26rpx;
  color: #8C8C8C;
}

.signup-count {
  color: #FF6B5B;
  font-weight: 700;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 距离显示 ===== */
.meta-item.distance {
  color: #4A90FF;
  font-weight: 500;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #FF6B5B;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}