/* WeUI 发布活动页 */
.page {
  min-height: 100vh;
  background: #F7F7F7;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 32rpx 24rpx;
  background: #fff;
}

.back-btn {
  font-size: 60rpx;
  color: #333;
  padding: 0 8rpx;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  padding-right: 68rpx;
}

/* 内容 */
.content {
  padding: 32rpx 32rpx 60rpx;
}

/* 按钮区域 */
.btn-area {
  margin-top: 48rpx;
}
