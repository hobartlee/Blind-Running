<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部 -->
  <view class="hero">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="hero-title">是否持有残疾人证明？</view>
  </view>

  <!-- 内容 -->
  <view class="content">
    <view class="choice-card {{hasProof === true ? 'selected' : ''}}" bindtap="selectProof" data-value="true">
      <view class="choice-icon">✓</view>
      <view class="choice-text">
        <view class="choice-name">有证明</view>
        <view class="choice-desc">可享受专属服务</view>
      </view>
    </view>

    <view class="choice-card {{hasProof === false ? 'selected' : ''}}" bindtap="selectProof" data-value="false">
      <view class="choice-icon">○</view>
      <view class="choice-text">
        <view class="choice-name">暂无证明</view>
        <view class="choice-desc">可使用平台部分功能</view>
      </view>
    </view>

    <view class="hint" wx:if="{{hasProof === false}}">暂无证明也可使用平台，可后续补充认证</view>

    <button
      class="btn {{hasProof !== null ? 'btn-active' : ''}}"
      bindtap="doNext"
      disabled="{{hasProof === null}}"
    >下一步</button>
  </view>
</view>
