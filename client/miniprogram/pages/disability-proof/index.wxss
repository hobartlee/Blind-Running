/* 残疾人证明页 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5F0 100%);
  position: relative;
  overflow: hidden;
}

/* 背景 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
}

.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #FFE4D6 0%, #FFDDD0 100%);
  top: -200rpx;
  right: -150rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #E8F4FF 0%, #D6EDFF 100%);
  bottom: 200rpx;
  left: -100rpx;
}

/* 顶部 */
.hero {
  padding: 100rpx 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF6B5B 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 100rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #2D2D2D;
  line-height: 1.3;
}

/* 返回按钮 */
.back-btn {
  font-size: 64rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 24rpx;
  display: inline-block;
}

/* 内容 */
.content {
  padding: 0 48rpx 60rpx;
  position: relative;
  z-index: 1;
}

/* 选择卡片 */
.choice-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.choice-card.selected {
  border-color: #FF8C69;
  background: #FFF9F5;
}

.choice-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  margin-right: 20rpx;
}

.choice-card.selected .choice-icon {
  background: #FF8C69;
  color: #fff;
}

.choice-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 4rpx;
}

.choice-desc {
  font-size: 24rpx;
  color: #999;
}

.hint {
  font-size: 26rpx;
  color: #FF9A4D;
  text-align: center;
  margin: 24rpx 0;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 96rpx;
  background: #e8e8e8;
  color: #fff;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 24rpx;
  transition: background 0.2s;
}

.btn-active {
  background: #FF8C69;
}

.btn::after {
  border: none;
}
