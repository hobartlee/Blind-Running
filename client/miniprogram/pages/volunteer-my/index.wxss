/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 背景装饰 ===== */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  pointer-events: none;
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #D4F0E5 0%, #E8F8F0 100%);
  border-radius: 50%;
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  opacity: 0.6;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  position: relative;
  z-index: 1;
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  padding-right: 60rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 24rpx 32rpx 140rpx;
  position: relative;
  z-index: 1;
}

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(7, 193, 96, 0.12);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #8C8C8C;
}

.edit-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #07C160;
  padding: 12rpx 24rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 100rpx;
}

/* ===== 信息区块 ===== */
.info-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8C8C8C;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #2D2D2D;
}

.info-value {
  font-size: 30rpx;
  color: #666;
}

.info-value.with-arrow {
  color: #07C160;
}

.info-value.admin {
  color: #FF6B5B;
  font-weight: 600;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #07C160;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 退出登录 ===== */
.logout-section {
  margin-top: 24rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B5B;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: none;
}
