/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  padding-right: 60rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 32rpx 140rpx;
}

/* ===== 活动信息卡片 ===== */
.activity-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.activity-info {
  flex: 1;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.activity-meta {
  font-size: 26rpx;
  color: #8C8C8C;
}

.btn-remind {
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

/* ===== 成员列表 ===== */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.member-avatar.accepted {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.member-avatar.completed {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.member-meta {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.member-experience {
  font-size: 22rpx;
  color: #07C160;
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.member-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-accept {
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.btn-reject {
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  background: #fff;
  color: #FF6B5B;
  border: 2rpx solid #FF6B5B;
  border-radius: 100rpx;
}

.member-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.member-status.waiting {
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  color: #FF9A4D;
}

.member-status.completed {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.empty-hint {
  text-align: center;
  padding: 60rpx;
  color: #B0B0B0;
  font-size: 28rpx;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #07C160;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
