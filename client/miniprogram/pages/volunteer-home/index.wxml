<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="header-left">
      <view class="logo-text">助盲跑</view>
    </view>
    <view class="header-right">
      <view class="switch-btn" bindtap="switchRole">切换</view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 审核状态 - 待审核 -->
    <view class="audit-banner pending anim-slide-up" wx:if="{{auditStatus === 'pending'}}">
      <view class="audit-icon-text">···</view>
      <view class="audit-content">
        <view class="audit-title">等待跑团审核中</view>
        <view class="audit-desc">您的加入申请已提交，请等待跑团审核。审核通过后即可发布活动。</view>
      </view>
    </view>

    <!-- 已加入跑团（审核通过） -->
    <block wx:if="{{joinedClub && auditStatus === 'approved'}}">
      <!-- 跑团信息卡片 -->
      <view class="club-card anim-slide-up" style="animation-delay: 0.05s">
        <view class="club-avatar-text">{{clubName ? clubName[0] : '跑'}}</view>
        <view class="club-info">
          <view class="club-name">{{clubName}}</view>
          <view class="club-role">已入驻 · 志愿者</view>
        </view>
        <view class="btn-view" bindtap="goToMyClub">查看跑团</view>
      </view>

      <!-- 统计 -->
      <view class="stats-row anim-slide-up" style="animation-delay: 0.1s" wx:if="{{activityCount > 0 || hours > 0}}">
        <view class="stat-item">
          <view class="stat-value">{{activityCount}}</view>
          <view class="stat-label">发布活动</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">{{hours}}</view>
          <view class="stat-label">陪伴时长(h)</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">4.9</view>
          <view class="stat-label">评分</view>
        </view>
      </view>

      <!-- 我的活动 -->
      <view class="section anim-slide-up" style="animation-delay: 0.15s">
        <view class="section-header">
          <view class="section-title">我的活动</view>
        </view>

        <!-- 活动筛选 -->
        <view class="filter-tabs" wx:if="{{filteredActivities.length > 0}}">
          <view
            class="filter-tab {{filter === 'all' ? 'active' : ''}}"
            bindtap="setFilter"
            data-filter="all"
          >全部</view>
          <view
            class="filter-tab {{filter === 'in_progress' ? 'active' : ''}}"
            bindtap="setFilter"
            data-filter="in_progress"
          >进行中</view>
          <view
            class="filter-tab {{filter === 'completed' ? 'active' : ''}}"
            bindtap="setFilter"
            data-filter="completed"
          >已完成</view>
        </view>

        <!-- 有活动数据 -->
        <view class="activity-list" wx:if="{{filteredActivities.length > 0}}">
          <view
            class="activity-card {{item.status === 'cancelled' ? 'cancelled' : ''}}"
            wx:for="{{filteredActivities}}"
            wx:key="id"
            bindtap="goToSignups"
            data-id="{{item.id}}"
          >
            <view class="activity-title">{{item.title}}</view>
            <view class="activity-meta">{{item.dateText}} · {{item.location}}</view>
            <view class="activity-footer">
              <view class="activity-signups">{{item.signups}} 人已报名</view>
              <view class="activity-badge badge-{{item.status}}">{{item.statusText}}</view>
            </view>
            <view class="activity-actions" wx:if="{{item.status !== 'cancelled' && item.status !== 'completed'}}">
              <view class="btn-cancel" catchtap="cancelActivity" data-id="{{item.id}}">取消活动</view>
            </view>
            <view class="cancel-hint" wx:if="{{item.status === 'cancelled'}}">已取消，请电话联络对方</view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:else>
          <view class="empty-icon-text">~</view>
          <view class="empty-text">暂无活动</view>
          <view class="empty-hint">发布您的第一个助跑活动吧</view>
        </view>
      </view>

      <!-- 发布活动按钮 -->
      <view class="btn-publish anim-slide-up" style="animation-delay: 0.2s" bindtap="goToCreateActivity">
        <text class="btn-icon">+</text>
        <text>发布新活动</text>
      </view>
    </block>

    <!-- 未加入跑团或审核未通过 -->
    <view class="no-club-card anim-slide-up" wx:if="{{!joinedClub && auditStatus !== 'pending'}}">
      <view class="no-club-icon-text">+</view>
      <view class="no-club-title">您还未加入跑团</view>
      <view class="no-club-desc">加入跑团后才能发布助跑活动</view>
      <view class="btn-join" bindtap="goToJoinClub">加入跑团</view>
    </view>

    <!-- 审核中状态 -->
    <view class="no-club-card anim-slide-up" wx:if="{{auditStatus === 'pending'}}">
      <view class="no-club-icon-text">...</view>
      <view class="no-club-title">等待跑团审核</view>
      <view class="no-club-desc">您的申请正在审核中，请耐心等待</view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item active">
      <view class="nav-icon-text">首</view>
      <view class="nav-label">首页</view>
    </view>
    <view class="nav-item" bindtap="goToMy">
      <view class="nav-icon-text">我</view>
      <view class="nav-label">我的</view>
    </view>
  </view>
</view>
