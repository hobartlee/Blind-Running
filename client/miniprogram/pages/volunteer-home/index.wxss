/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.header-left {
  display: flex;
  align-items: center;
}

.logo-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.header-right {
  display: flex;
  align-items: center;
}

.switch-btn {
  font-size: 24rpx;
  color: #fff;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 40rpx 160rpx;
}

/* ===== 审核横幅 ===== */
.audit-banner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.audit-banner.pending {
  border-left: 6rpx solid #FFB366;
  background: linear-gradient(135deg, #FFFBF5 0%, #FFF8F0 100%);
}

.audit-banner.approved {
  border-left: 6rpx solid #07C160;
  background: linear-gradient(135deg, #F0FFF5 0%, #E8F8F0 100%);
}

.audit-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.audit-banner.pending .audit-icon {
  background: linear-gradient(135deg, #FFB366 0%, #FF9A4D 100%);
  color: #fff;
}

.audit-banner.approved .audit-icon {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
}

.audit-content {
  flex: 1;
}

.audit-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.audit-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.club-name {
  color: #07C160;
  font-weight: 600;
}

/* ===== 未加入跑团卡片 ===== */
.no-club-card {
  background: #fff;
  border: 2rpx dashed #D0D0D0;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.no-club-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.no-club-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.no-club-desc {
  font-size: 28rpx;
  color: #8C8C8C;
  margin-bottom: 32rpx;
}

.btn-join {
  display: inline-block;
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 255, 0.3);
}

/* ===== 跑团卡片 ===== */
.club-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.club-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.club-info {
  flex: 1;
}

.club-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.club-role {
  font-size: 26rpx;
  color: #8C8C8C;
}

.btn-view {
  font-size: 26rpx;
  color: #07C160;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  border-radius: 100rpx;
}

/* ===== 统计 ===== */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #07C160;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8C8C8C;
}

.stat-divider {
  width: 1px;
  height: 60rpx;
  background: #E8E8E8;
  margin: 0 20rpx;
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 32rpx;
}

/* ===== 筛选标签 ===== */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-tab {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #8C8C8C;
  background: #fff;
  border-radius: 100rpx;
  transition: all 0.3s ease;
}

.filter-tab.active {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

/* ===== 活动列表 ===== */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.activity-meta {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.activity-signups {
  font-size: 26rpx;
  color: #8C8C8C;
}

.activity-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-upcoming {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.badge-pending {
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  color: #FF9A4D;
}

.activity-card.cancelled {
  opacity: 0.6;
}

.activity-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid #F0F0F0;
  display: flex;
  justify-content: flex-end;
}

.btn-cancel {
  font-size: 24rpx;
  color: #FF6B5B;
  padding: 8rpx 20rpx;
  background: #FFF5F5;
  border-radius: 8rpx;
}

.cancel-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #FF6B5B;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 发布按钮 ===== */
.btn-publish {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.btn-icon {
  font-size: 40rpx;
  font-weight: 300;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #07C160;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}