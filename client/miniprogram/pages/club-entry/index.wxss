/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

/* ===== 内容区域 ===== */
.content {
  flex: 1;
  padding: 120rpx 48rpx 60rpx;
}

/* ===== Logo区域 ===== */
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.logo-desc {
  font-size: 28rpx;
  color: #8C8C8C;
}

/* ===== 选项列表 ===== */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F7F7F7;
  border-radius: 24rpx;
  padding: 36rpx;
  transition: all 0.3s ease;
}

.option-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.option-card.primary {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.option-card.primary .option-title,
.option-card.primary .option-sub {
  color: #fff;
}

.option-card.primary .option-icon {
  background: rgba(255, 255, 255, 0.2);
}

.option-card.primary .option-arrow {
  color: rgba(255, 255, 255, 0.7);
}

.option-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.option-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #EBF0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.option-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.option-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.option-sub {
  font-size: 26rpx;
  color: #8C8C8C;
}

.option-arrow {
  font-size: 48rpx;
  color: #CCC;
  font-weight: 300;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
