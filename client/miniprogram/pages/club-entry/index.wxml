<view class="page">
  <!-- 内容区域 -->
  <view class="content">
    <!-- Logo区域 -->
    <view class="logo-section anim-slide-up">
      <view class="logo-icon-text">跑</view>
      <view class="logo-text">跑团后台</view>
      <view class="logo-desc">管理志愿者，组织活动</view>
    </view>

    <!-- 选项卡片 -->
    <view class="option-list">
      <view class="option-card anim-slide-up" style="animation-delay: 0.1s" bindtap="goToLogin">
        <view class="option-left">
          <view class="option-icon">🔑</view>
          <view class="option-text">
            <view class="option-title">已有跑团登录</view>
            <view class="option-sub">管理已入驻的跑团</view>
          </view>
        </view>
        <view class="option-arrow">›</view>
      </view>

      <view class="option-card primary anim-slide-up" style="animation-delay: 0.15s" bindtap="goToRegister">
        <view class="option-left">
          <view class="option-icon">✨</view>
          <view class="option-text">
            <view class="option-title">入驻新跑团</view>
            <view class="option-sub">创建跑团，开始招募</view>
          </view>
        </view>
        <view class="option-arrow">›</view>
      </view>
    </view>
  </view>
</view>
