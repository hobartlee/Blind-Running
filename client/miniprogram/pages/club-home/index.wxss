/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, #EBF0FF 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.logo-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.switch-btn {
  font-size: 24rpx;
  color: #fff;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 100rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 32rpx 140rpx;
}

/* ===== 跑团卡片 ===== */
.club-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: -20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(74, 144, 255, 0.15);
}

.club-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.club-info {
  flex: 1;
}

.club-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.club-role {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.club-stats {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #666;
}

/* ===== 统计 ===== */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #4A90FF;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8C8C8C;
}

.stat-divider {
  width: 1px;
  height: 60rpx;
  background: #E8E8E8;
  margin: 0 16rpx;
}

/* ===== 标签页 ===== */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.tab {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  text-align: center;
  transition: all 0.3s ease;
}

.tab.active {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 255, 0.3);
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #8C8C8C;
  margin-bottom: 20rpx;
}

.btn-add {
  font-size: 26rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  color: #fff;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 255, 0.3);
}

/* ===== 活动列表 ===== */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  flex: 1;
  margin-right: 16rpx;
}

.activity-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-upcoming {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

.badge-pending {
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  color: #FF9A4D;
}

.activity-meta {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
}

.activity-footer {
  display: flex;
  justify-content: flex-end;
}

.activity-signups {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 成员列表 ===== */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.member-card.pending {
  border-left: 6rpx solid #FFB366;
  background: linear-gradient(135deg, #FFFBF5 0%, #FFF8F0 100%);
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.member-meta {
  font-size: 24rpx;
  color: #8C8C8C;
}

.btn-approve {
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.empty-hint {
  text-align: center;
  padding: 40rpx;
  color: #B0B0B0;
  font-size: 28rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.empty-state.small {
  padding: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.empty-hint-text {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* 兼容旧class名 */
.empty-hint {
  font-size: 26rpx;
  color: #8C8C8C;
  text-align: center;
  padding: 40rpx;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #4A90FF;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Tab content visibility */
.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}