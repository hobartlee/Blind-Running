<view class="page {{userType === 'volunteer' ? 'page-vol' : userType === 'blind' ? 'page-blind' : 'page-group'}}">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部 -->
  <view class="hero">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="hero-title">{{title}}</view>
  </view>

  <!-- 内容 -->
  <view class="content">
    <view class="intro-card">{{desc}}</view>

    <view class="guide-card">
      <view class="guide-title">{{guideTitle}}</view>
      <view class="guide-list">
        <view class="guide-item" wx:for="{{guideItems}}" wx:key="*this">
          <text class="guide-dot">·</text>
          <text class="guide-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view
      class="agree-row {{agreed ? 'checked' : ''}}"
      bindtap="toggleAgree"
    >
      <view class="agree-circle">
        <text wx:if="{{agreed}}">✓</text>
      </view>
      <view class="agree-text">{{agreeText}}</view>
    </view>

    <button
      class="btn {{agreed ? 'btn-active' : ''}}"
      bindtap="doSubmit"
      disabled="{{!agreed}}"
    >{{submitText}}</button>
  </view>
</view>
