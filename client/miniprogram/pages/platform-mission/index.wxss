/* 服务须知页 - 三套配色 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5F0 100%);
  position: relative;
  overflow: hidden;
}

/* 志愿者配色 */
.page-vol {
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
}

/* 跑团配色 */
.page-group {
  background: linear-gradient(180deg, #F0F5FF 0%, #EEF2FF 100%);
}

/* 背景 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
}

.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #FFE4D6 0%, #FFDDD0 100%);
  top: -200rpx;
  left: -150rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #E8F4FF 0%, #D6EDFF 100%);
  bottom: 200rpx;
  right: -100rpx;
}

.page-vol .bg-circle-1 {
  background: linear-gradient(135deg, #D4F0E5 0%, #E8F8F0 100%);
}

.page-vol .bg-circle-2 {
  background: linear-gradient(135deg, #FFE4D6 0%, #FFDDD0 100%);
}

.page-group .bg-circle-1 {
  background: linear-gradient(135deg, #D6E4FF 0%, #D6EDFF 100%);
}

.page-group .bg-circle-2 {
  background: linear-gradient(135deg, #D4F0E5 0%, #E8F8F0 100%);
}

/* 顶部 */
.hero {
  padding: 100rpx 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF6B5B 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 100rpx;
  margin-bottom: 20rpx;
}

.page-vol .hero-badge {
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
}

.page-group .hero-badge {
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #2D2D2D;
  line-height: 1.3;
}

/* 返回按钮 */
.back-btn {
  font-size: 64rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 24rpx;
  display: inline-block;
}

/* 内容 */
.content {
  padding: 0 48rpx 60rpx;
  position: relative;
  z-index: 1;
}

/* 介绍卡片 */
.intro-card {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 准则卡片 */
.guide-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.guide-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 20rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.guide-item:last-child {
  border-bottom: none;
}

.guide-dot {
  color: #07C160;
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
}

/* 同意 */
.agree-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.agree-circle {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  transition: all 0.2s;
}

.agree-row.checked .agree-circle {
  background: #07C160;
  border-color: #07C160;
}

.page-blind .agree-row.checked .agree-circle {
  background: #FF8C69;
  border-color: #FF8C69;
}

.page-group .agree-row.checked .agree-circle {
  background: #4A90FF;
  border-color: #4A90FF;
}

.agree-text {
  font-size: 28rpx;
  color: #666;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 96rpx;
  background: #e8e8e8;
  color: #fff;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: background 0.2s;
}

.btn-active {
  background: #07C160;
}

.page-blind .btn-active {
  background: #FF8C69;
}

.page-group .btn-active {
  background: #4A90FF;
}

.btn::after {
  border: none;
}
