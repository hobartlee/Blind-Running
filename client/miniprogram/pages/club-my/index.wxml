<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">跑团设置</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 跑团信息 -->
    <view class="user-card anim-slide-up">
      <view class="user-avatar-text">{{clubName ? clubName[0] : '跑'}}</view>
      <view class="user-info">
        <view class="user-name">{{clubName || '我的跑团'}}</view>
        <view class="user-role">管理员</view>
      </view>
    </view>

    <!-- 待审核志愿者 -->
    <view class="info-section anim-slide-up" style="animation-delay: 0.05s" wx:if="{{pendingCount > 0}}">
      <view class="section-title">待审核</view>
      <view class="pending-card" bindtap="goToVolunteerManage">
        <view class="pending-info">
          <view class="pending-count">{{pendingCount}}</view>
          <view class="pending-text">位志愿者申请加入</view>
        </view>
        <view class="pending-action">
          <view class="action-btn">立即审核 ›</view>
        </view>
      </view>
    </view>

    <!-- 设置菜单 -->
    <view class="menu-card anim-slide-up" style="animation-delay: 0.1s" bindtap="goToVolunteerManage">
      <view class="menu-icon">👥</view>
      <view class="menu-content">
        <view class="menu-title">志愿者管理</view>
        <view class="menu-sub">管理 {{memberCount}} 位志愿者</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>

    <view class="menu-card anim-slide-up" style="animation-delay: 0.15s">
      <view class="menu-icon">📊</view>
      <view class="menu-content">
        <view class="menu-title">跑团数据</view>
        <view class="menu-sub">已发布 {{activityCount}} 期活动，帮助 {{helpedCount}} 人次</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>

    <view class="menu-card anim-slide-up" style="animation-delay: 0.2s">
      <view class="menu-icon">⚙️</view>
      <view class="menu-content">
        <view class="menu-title">基本设置</view>
        <view class="menu-sub">跑团名称、简介、地点</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToHome">
      <view class="nav-icon">🏠</view>
      <view class="nav-label">首页</view>
    </view>
    <view class="nav-item active">
      <view class="nav-icon">⚙</view>
      <view class="nav-label">设置</view>
    </view>
  </view>
</view>
