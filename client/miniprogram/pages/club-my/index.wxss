/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, #EBF0FF 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  padding-right: 60rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 32rpx 140rpx;
}

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: -20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(74, 144, 255, 0.12);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90FF 0%, #2563FF 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 信息区块 ===== */
.info-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8C8C8C;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ===== 待审核卡片 ===== */
.pending-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF5E8 0%, #FFE8D6 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border-left: 8rpx solid #FF9A4D;
}

.pending-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pending-count {
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6B5B;
}

.pending-text {
  font-size: 28rpx;
  color: #666;
}

.pending-action {
  flex-shrink: 0;
}

.action-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B5B;
  padding: 12rpx 24rpx;
  background: rgba(255, 107, 91, 0.1);
  border-radius: 100rpx;
}

/* ===== 菜单卡片 ===== */
.menu-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.menu-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-icon {
  font-size: 48rpx;
  width: 56rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.menu-sub {
  font-size: 26rpx;
  color: #8C8C8C;
}

.menu-arrow {
  font-size: 48rpx;
  color: #CCC;
  font-weight: 300;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #4A90FF;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
