/* ===== 页面容器 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5F0 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #FF9A7A 0%, #FF8C69 100%);
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  padding: 0 10rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  padding-right: 60rpx;
}

/* ===== 内容区域 ===== */
.content {
  padding: 0 32rpx 140rpx;
}

/* ===== 卡片 ===== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  flex: 1;
  margin-right: 16rpx;
}

.activity-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
}

.activity-badge.club {
  background: linear-gradient(135deg, #E8F8F0 0%, #D4F0E5 100%);
  color: #07C160;
}

/* ===== 信息列表 ===== */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.info-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 30rpx;
  color: #2D2D2D;
}

/* ===== 分隔线 ===== */
.activity-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #E8E8E8 50%, transparent 100%);
  margin: 24rpx 0;
}

/* ===== 备注 ===== */
.activity-note {
  padding-top: 8rpx;
}

.note-label {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-bottom: 8rpx;
}

.note-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* ===== 组织者 ===== */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 20rpx;
}

.organizer-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.organizer-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A7A 0%, #FF8C69 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}

.organizer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.organizer-sub {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* ===== 统计 ===== */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6B5B;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8C8C8C;
}

/* ===== 报名按钮 ===== */
.btn-signup {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9A7A 0%, #FF8C69 100%);
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 105, 0.3);
}

.btn-signup:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ===== 底部导航 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  padding: 16rpx 0;
  padding-bottom: max(16rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.03);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx;
  color: #B0B0B0;
}

.nav-item.active {
  color: #FF6B5B;
}

.nav-icon {
  font-size: 44rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 动画 ===== */
.anim-slide-up {
  animation: slideUp 0.5s ease-out forwards;
  opacity: 0;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
