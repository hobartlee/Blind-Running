<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">活动详情</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 活动信息 -->
    <view class="card anim-slide-up">
      <view class="activity-header">
        <view class="activity-title">{{activity.title}}</view>
        <view class="activity-badge club">{{activity.clubName}}</view>
      </view>

      <view class="info-list">
        <view class="info-item">
          <view class="info-label-text">日期</view>
          <view class="info-value">{{activity.dateText}}</view>
        </view>
        <view class="info-item">
          <view class="info-label-text">时间</view>
          <view class="info-value">{{activity.timeText}}</view>
        </view>
        <view class="info-item">
          <view class="info-label-text">地点</view>
          <view class="info-value">{{activity.location}}</view>
        </view>
        <view class="info-item">
          <view class="info-label-text">时长</view>
          <view class="info-value">{{activity.durationText}}</view>
        </view>
        <view class="info-item">
          <view class="info-label-text">方式</view>
          <view class="info-value">{{activity.methodText}}</view>
        </view>
      </view>

      <view class="activity-divider" wx:if="{{activity.note}}"></view>
      <view class="activity-note" wx:if="{{activity.note}}">
        <view class="note-label">备注</view>
        <view class="note-content">{{activity.note}}</view>
      </view>
    </view>

    <!-- 组织者信息 -->
    <view class="card anim-slide-up" style="animation-delay: 0.05s">
      <view class="card-title">组织者</view>
      <view class="organizer-row">
        <view class="organizer-avatar">{{activity.author.charAt(0)}}</view>
        <view class="organizer-info">
          <view class="organizer-name">{{activity.author}}</view>
          <view class="organizer-sub">{{activity.clubName}}</view>
        </view>
      </view>
    </view>

    <!-- 报名统计 -->
    <view class="card anim-slide-up" style="animation-delay: 0.1s">
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-value">{{activity.signups}}</view>
          <view class="stat-label">已报名</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{activity.confirmed}}</view>
          <view class="stat-label">已确认</view>
        </view>
      </view>
    </view>

    <!-- 报名按钮 -->
    <view class="btn-signup anim-slide-up" style="animation-delay: 0.15s" bindtap="doSignup">报名参加</view>
  </view>
</view>
