<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部 -->
  <view class="hero">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="hero-title">填写基本信息</view>
    <view class="hero-subtitle">让志愿者更了解您</view>
  </view>

  <!-- 内容 -->
  <view class="content">
    <!-- 姓名 -->
    <view class="field-card">
      <view class="field-icon">👤</view>
      <view class="field-group">
        <view class="field-label">姓名</view>
        <input
          class="field-input"
          type="text"
          placeholder="请输入姓名"
          placeholder-class="placeholder"
          bindinput="onNameInput"
          value="{{name}}"
        />
      </view>
    </view>

    <!-- 性别 -->
    <view class="field-card">
      <view class="field-icon">⚥</view>
      <view class="field-group">
        <view class="field-label">性别</view>
        <view class="gender-row">
          <view
            class="gender-btn {{gender === 'male' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="male"
          >男</view>
          <view
            class="gender-btn {{gender === 'female' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="female"
          >女</view>
        </view>
      </view>
    </view>

    <!-- 年龄 -->
    <view class="field-card" wx:if="{{userType !== 'volunteer'}}">
      <view class="field-icon">🎂</view>
      <view class="field-group">
        <view class="field-label">年龄</view>
        <input
          class="field-input"
          type="number"
          placeholder="请输入年龄"
          placeholder-class="placeholder"
          bindinput="onAgeInput"
          value="{{age}}"
        />
      </view>
    </view>

    <!-- 跑步经验 -->
    <view class="field-card">
      <view class="field-icon">🏃</view>
      <view class="field-group">
        <view class="field-label">跑步经验</view>
        <view class="exp-row">
          <view
            class="exp-btn {{experience === 'none' ? 'active' : ''}}"
            bindtap="selectExperience"
            data-exp="none"
          >无经验</view>
          <view
            class="exp-btn {{experience === 'intermediate' ? 'active' : ''}}"
            bindtap="selectExperience"
            data-exp="intermediate"
          >有经验</view>
          <view
            class="exp-btn {{experience === 'experienced' ? 'active' : ''}}"
            bindtap="selectExperience"
            data-exp="experienced"
          >经验丰富</view>
        </view>
      </view>
    </view>

    <button
      class="btn {{canSubmit ? 'btn-active' : ''}}"
      bindtap="doSubmit"
      disabled="{{!canSubmit}}"
    >完成</button>
  </view>
</view>
