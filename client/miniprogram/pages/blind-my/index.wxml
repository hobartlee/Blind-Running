<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
  </view>

  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">我的</view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 用户信息卡片 -->
    <view class="user-card anim-slide-up">
      <view class="user-avatar">{{userInfo.name ? userInfo.name[0] : '盲'}}</view>
      <view class="user-info">
        <view class="user-name">{{userInfo.name || '视障跑者'}}</view>
        <view class="user-phone">{{maskedPhone || '138****8888'}}</view>
      </view>
      <view class="edit-btn" bindtap="editProfile">编辑</view>
    </view>

    <!-- 个人信息列表 -->
    <view class="info-section anim-slide-up" style="animation-delay: 0.1s">
      <view class="section-title">个人信息</view>
      <view class="info-card">
        <view class="info-row">
          <view class="info-label">姓名</view>
          <view class="info-value">{{userInfo.name || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">性别</view>
          <view class="info-value">{{genderText || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">年龄</view>
          <view class="info-value">{{userInfo.age ? userInfo.age + '岁' : '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">跑步经验</view>
          <view class="info-value">{{experienceText || '未填写'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">手机号</view>
          <view class="info-value">{{maskedPhone || '未填写'}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToHome">
      <view class="nav-icon-text">首</view>
      <view class="nav-label">首页</view>
    </view>
    <view class="nav-item active">
      <view class="nav-icon-text">我</view>
      <view class="nav-label">我的</view>
    </view>
  </view>
</view>
