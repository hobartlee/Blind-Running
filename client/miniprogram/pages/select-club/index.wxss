/* WeUI 选择跑团页 */
.page {
  min-height: 100vh;
  background: #F7F7F7;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 80rpx 32rpx 24rpx;
  background: #fff;
}

.back-btn {
  font-size: 60rpx;
  color: #333;
  padding: 0 8rpx;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  padding-right: 68rpx;
}

/* 内容 */
.content {
  padding: 32rpx 32rpx 60rpx;
}

/* 介绍区域 */
.intro-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.intro-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.intro-desc {
  font-size: 26rpx;
  color: #666;
}

/* 跑团列表 */
.club-list {
  margin-bottom: 32rpx;
}

.club-card {
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.club-card.selected {
  border-color: #07C160;
  background: #F0FFF5;
}

.club-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.club-info {
  flex: 1;
}

.club-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.club-meta {
  font-size: 24rpx;
  color: #999;
}

.club-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #07C160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
}

/* 按钮区域 */
.btn-area {
  margin-top: 32rpx;
}
