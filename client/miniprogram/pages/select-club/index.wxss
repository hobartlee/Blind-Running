/* 选择跑团页 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF5 0%, #E8F8F0 100%);
  position: relative;
  overflow: hidden;
}

/* 背景 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
}

.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #D4F0E5 0%, #E8F8F0 100%);
  top: -200rpx;
  left: -150rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #FFE4D6 0%, #FFDDD0 100%);
  bottom: 200rpx;
  right: -100rpx;
}

/* 顶部 */
.hero {
  padding: 100rpx 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 100rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #2D2D2D;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #8C8C8C;
}

/* 返回按钮 */
.back-btn {
  font-size: 64rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 24rpx;
  display: inline-block;
}

/* 内容 */
.content {
  padding: 0 48rpx 60rpx;
  position: relative;
  z-index: 1;
}

/* 跑团卡片 */
.club-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.club-card.selected {
  border-color: #07C160;
  background: #F0FFF5;
}

.club-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #07C160 0%, #05A050 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-right: 20rpx;
}

.club-info {
  flex: 1;
}

.club-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.club-meta {
  font-size: 24rpx;
  color: #999;
}

.club-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #07C160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 96rpx;
  background: #e8e8e8;
  color: #fff;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 24rpx;
  transition: background 0.2s;
}

.btn-active {
  background: #07C160;
}

.btn::after {
  border: none;
}
