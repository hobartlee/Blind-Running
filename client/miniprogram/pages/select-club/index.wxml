<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部 -->
  <view class="hero">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="hero-title">加入一个跑团</view>
    <view class="hero-subtitle">入驻后可以发布和管理活动</view>
  </view>

  <!-- 列表 -->
  <view class="content">
    <view
      class="club-card {{selectedClubId === item.id ? 'selected' : ''}}"
      wx:for="{{clubs}}"
      wx:key="id"
      bindtap="selectClub"
      data-id="{{item.id}}"
    >
      <view class="club-avatar">{{item.name.charAt(0)}}</view>
      <view class="club-info">
        <view class="club-name">{{item.name}}</view>
        <view class="club-meta">{{item.location}} · {{item.members}}名成员</view>
      </view>
      <view class="club-check" wx:if="{{selectedClubId === item.id}}">✓</view>
    </view>

    <button
      class="btn {{selectedClubId ? 'btn-active' : ''}}"
      bindtap="doJoin"
      disabled="{{!selectedClubId}}"
    >申请加入</button>
  </view>
</view>
