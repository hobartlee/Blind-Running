<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="title">志愿者管理</view>
  </view>

  <!-- 标签页 -->
  <view class="tabs-wrap">
    <view class="tabs anim-slide-up">
      <view
        class="tab {{activeTab === 'pending' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="pending"
      >
        待审核
        <view class="tab-badge" wx:if="{{pendingList.length > 0}}">{{pendingList.length}}</view>
      </view>
      <view
        class="tab {{activeTab === 'members' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="members"
      >志愿者</view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 待审核列表 -->
    <view class="tab-content {{activeTab === 'pending' ? 'active' : ''}}">
      <view class="volunteer-card anim-slide-up" wx:for="{{pendingList}}" wx:key="id">
        <view class="volunteer-header">
          <view class="volunteer-avatar">{{item.name[0]}}</view>
          <view class="volunteer-info">
            <view class="volunteer-name">{{item.name}}</view>
            <view class="volunteer-meta">{{item.gender}} · {{item.age}}岁 · {{item.experience}}</view>
          </view>
          <view class="volunteer-time">{{item.applyTime}}</view>
        </view>

        <view class="volunteer-tags">
          <view class="tag" wx:if="{{item.runCount > 0}}">跑步 {{item.runCount}} 次</view>
          <view class="tag" wx:if="{{item.points > 0}}">积分 {{item.points}}</view>
        </view>

        <view class="volunteer-actions">
          <view class="action-reject" bindtap="rejectVolunteer" data-id="{{item.id}}">拒绝</view>
          <view class="action-approve" bindtap="approveVolunteer" data-id="{{item.id}}">通过</view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{pendingList.length === 0}}">
        <view class="empty-icon">👥</view>
        <view class="empty-title">暂无待审核志愿者</view>
        <view class="empty-desc">志愿者申请加入后将显示在这里</view>
      </view>
    </view>

    <!-- 志愿者列表 -->
    <view class="tab-content {{activeTab === 'members' ? 'active' : ''}}">
      <view class="volunteer-card anim-slide-up" wx:for="{{memberList}}" wx:key="id">
        <view class="volunteer-header">
          <view class="volunteer-avatar">{{item.name[0]}}</view>
          <view class="volunteer-info">
            <view class="volunteer-name">{{item.name}}
              <text class="level-badge" wx:if="{{item.level}}">{{item.level}}</text>
            </view>
            <view class="volunteer-meta">跑步 {{item.runCount}} 次 · {{item.points}} 积分</view>
          </view>
        </view>

        <view class="member-stats">
          <view class="stat-item">
            <view class="stat-value">{{item.activityCount}}</view>
            <view class="stat-label">参与活动</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{item.helpHours}}</view>
            <view class="stat-label">帮助时长(h)</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{item.blindCount}}</view>
            <view class="stat-label">服务盲人</view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{memberList.length === 0}}">
        <view class="empty-icon">👥</view>
        <view class="empty-title">暂无志愿者</view>
        <view class="empty-desc">招募志愿者后他们将显示在这里</view>
      </view>
    </view>
  </view>
</view>
